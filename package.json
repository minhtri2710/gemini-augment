{
	"name": "gemini-augment",
	"version": "0.2.2",
	"description": "Augment-style prompt rewriting for Gemini CLI via /augment.",
	"type": "module",
	"private": true,
	"bin": {
		"gemini-augment": "dist/index.js"
	},
	"main": "dist/index.js",
	"files": [
		"dist",
		"commands",
		"skills",
		"gemini-extension.json",
		"package.json",
		"GEMINI.md",
		"README.md",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json && esbuild src/index.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/index.js",
		"start": "node dist/index.js",
		"dev": "node --import=tsx src/index.ts",
		"format": "biome format --write .",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"lint:ci": "biome ci .",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"smoke-test": "node --import=tsx --test test/mcp-smoke.test.ts",
		"test": "node --test dist/test/*.test.js",
		"test:src": "node --import=tsx --test test/*.test.ts",
		"clean": "rm -rf dist && rm -rf node_modules",
		"preflight": "npm run clean && npm ci && npm run format && npm run lint || true && npm run build && npm run typecheck",
		"check": "npm run lint && npm run typecheck && npm run build && npm run test",
		"postinstall": "npm run build"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.18.1",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@types/node": "^22.10.2",
		"esbuild": "^0.25.11",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	},
	"engines": {
		"node": ">=22"
	}
}
