{
  "name": "gemini-augment",
  "version": "0.1.0",
  "description": "Augment-style prompt rewriting for Gemini CLI via /augment.",
  "type": "module",
  "private": true,
  "bin": {
    "gemini-augment": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "commands",
    "skills",
    "gemini-extension.json",
    "package.json",
    "GEMINI.md",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/index.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke-test": "node --import=tsx --test test/mcp-smoke.test.ts",
    "test": "node --test dist/test/*.test.js",
    "test:src": "node --import=tsx --test test/*.test.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "npm run lint && npm run typecheck && npm run build && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "^22.10.2",
    "esbuild": "^0.25.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22"
  }
}
