{
	"name": "gemini-augment",
	"version": "0.1.0",
	"description": "Augment-style prompt rewriting for Gemini CLI via /augment.",
	"type": "module",
	"private": true,
	"files": [
		"dist",
		"gemini-extension.json",
		"package.json",
		"GEMINI.md"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"smoke-test": "node --import=tsx --test test/mcp-smoke.test.ts",
		"test": "node --test dist/test/*.test.js",
		"test:src": "node --import=tsx --test test/*.test.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"check": "npm run lint && npm run typecheck && npm run build && npm run test"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.18.1",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@types/node": "^22.10.2",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	},
	"engines": {
		"node": ">=22"
	}
}
